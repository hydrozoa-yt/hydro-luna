[oploc1,rcu_outer_multi1]
switch_int (%rcu_abyssal_generator) {
    case 0 : return; // blockage
    case 1 : @rcu_break_rock;
    case 2 : @rcu_chop_tendrils;
    case 3 : @rcu_burn_down_boil;
    case 4 : @rcu_distract_eyes;
    case 5 : @rcu_squeeze_through_gap;
    case 6 : @rcu_go_through_passage;
    case 7 : @rcu_squeeze_through_gap;
    case 8 : @rcu_distract_eyes;
    case 9 : @rcu_burn_down_boil;
    case 10 : @rcu_chop_tendrils;
    case 11 : @rcu_break_rock;
}


[debugproc,teleabyss]
if (p_finduid(uid) = false) return;
@rcu_teleport_to_abyss;

[label,rcu_teleport_to_abyss]
%rcu_abyssal_generator = randominc(^rcu_abyss_layout_count);
def_coord $base_coord = enum(int, coord, rcu_abyss_entry_coords, %rcu_abyssal_generator);
p_telejump(map_findsquare($base_coord, 0, 5, ^map_findsquare_lineofwalk));

stat_drain(prayer, 99, 0);
~pk_skull(^rcu_pk_skull_duration);

// OSRS - Delays the player for a tick after tp'ing in
anim(null, 0);
p_delay(0);

[label,rcu_break_rock]
def_namedobj $pickaxe = rune_pickaxe; // TODO: fixme, pickaxe check

if ($pickaxe = null) {
    mes("You need a pickaxe for which you have the required Mining level to mine this rock.");
    return;
}
mes("You attempt to mine your way through...");
anim(human_mining_mithril_pickaxe, 0); // TODO: fixme, pickaxe anim
sound_synth(mining_3, 0, 0); // guess
~rcu_loc_face_center;
p_delay(7);

if (stat_random(mining, 0, 255) = true) {
    cam_moveto(coord, 2500, 0, 0);
    cam_lookat(loc_coord, 0, 10, 10);

    %rcu_abyssal_generator = 12;
    p_delay(1);
    %rcu_abyssal_generator = 13;
    
    p_teleport(loc_param(rcu_outer_enter_coord));
    p_delay(2);

    p_telejump(loc_param(rcu_outer_inner_coord));
    p_delay(0);
    cam_reset;

    clearqueue(damage_player);
    %rcu_abyssal_generator = 0;
    stat_advance(mining, 250);
    mes("...and manage to break through the rock.");
} else {
    clearqueue(damage_player);
    mes("...but fail to break-up the rock.");
}

[label,rcu_chop_tendrils]
mes("You attempt to chop your way through...");

~rcu_loc_face_center;
p_delay(3);

def_namedobj $axe = mithril_axe; // TODO: fixme, axe check

if ($axe = null) {
    mes("You need an axe to chop through the tendrils.");
    mes("You do not have an axe that you have the Woodcutting level to use.");
    return;
}
anim(human_woodcutting_mithril_axe, 0); // TODO: fixme, correct axe anim
sound_synth(woodchop_quick, 0, 0); // guess
p_delay(1);

if (stat_random(woodcutting, 0, 255) = true) {
    anim(human_woodcutting_mithril_axe, 0); // TODO: fixme, correct axe anim
    sound_synth(woodchop_quick, 0, 0); // guess
    cam_moveto(coord, 2500, 0, 0);
    cam_lookat(loc_coord, 0, 10, 10);
    p_delay(1);

    %rcu_abyssal_generator = 14;
    anim(human_woodcutting_mithril_axe, 0); // TODO: fixme, correct axe anim
    sound_synth(woodchop_quick, 0, 0); // guess
    p_delay(1);
    
    %rcu_abyssal_generator = 15;
    p_teleport(loc_param(rcu_outer_enter_coord));
    p_delay(1);

    mes("...and manage to cut a way through the tendrils.");
    p_delay(0);

    p_telejump(loc_param(rcu_outer_inner_coord));
    p_delay(0);

    cam_reset;
    clearqueue(damage_player);
    %rcu_abyssal_generator = 0;
    stat_advance(woodcutting, 250);
} else {
    clearqueue(damage_player);
    mes("...but fail to cut through the tendrils.");
}

[label,rcu_distract_eyes]
mes("You use your thieving skills to misdirect the eyes...");
~rcu_loc_face_center;
p_delay(1);

if (stat_random(thieving, 0, 255) = true) {
    anim(~rcu_distract_eyes_rand_anim, 0);
    cam_moveto(coord, 2500, 0, 0);
    cam_lookat(loc_coord, 0, 10, 10);
    p_delay(1);

    anim(~rcu_distract_eyes_rand_anim, 0);
    %rcu_abyssal_generator = 18;
    p_delay(1);

    %rcu_abyssal_generator = 19;
    p_teleport(loc_param(rcu_outer_enter_coord));
    p_delay(1);

    p_telejump(loc_param(rcu_outer_inner_coord));
    mes("...and sneak past while they're not looking.");
    p_delay(0);

    cam_reset;
    clearqueue(damage_player);
    %rcu_abyssal_generator = 0;
    stat_advance(thieving, 250);
} else {
    clearqueue(damage_player);
    mes("...but fail to distract them enough to get past.");
}

// TODO: Find out more anims that are used here
[proc,rcu_distract_eyes_rand_anim]()(seq)
switch_int (random(4)) {
    case 0 : return (human_stamp);
    case 1 : return (human_chicken_dance);
    case 2 : return (emote_beckon);
    case 3 : return (emote_clap);
    case default : return (emote_climbing_rope);
}

[label,rcu_squeeze_through_gap]
mes("You attempt to squeeze through the narrow gap...");
~rcu_loc_face_center;
p_delay(1);

anim(viking_drop_to_knee, 0);
p_delay(3);

if (stat_random(agility, 0, 255) = true) {
    // https://youtu.be/IhfNuSQukOQ?si=CwEgAlQhLc91mAPd&t=70
    // Due to camera packet buffering this looks very broken (matches osrs through), should camera packets be buffered?
    cam_moveto(coord, 2500, 0, 0);
    cam_lookat(loc_coord, 0, 10, 10);
    anim(human_crawling, 0);
    mes("...and you manage to crawl through.");
    p_telejump(loc_param(rcu_outer_inner_coord));
    sound_synth(abyssal_squeezethrough, 4, 0);
    p_delay(0);

    clearqueue(damage_player);
    %rcu_abyssal_generator = 0;
    cam_reset;
    stat_advance(agility, 250);
} else {
    anim(viking_drop_to_knee_and_backtoready, 0);
    mes("...but you are not agile enough to get through the gap.");
}

[label,rcu_burn_down_boil]
mes("You attempt to set the blockade on fire...");
~rcu_loc_face_center;
p_delay(2);

if (inv_total(inv, tinderbox) = 0) {
    mes("...but you don't have a tinderbox to burn it!");
    return;
}

if (stat_random(firemaking, 0, 255) = true) {
    anim(human_createfire, 0);
    cam_moveto(coord, 2500, 0, 0);
    cam_lookat(loc_coord, 0, 10, 10);
    p_delay(5);

    %rcu_abyssal_generator = 16;
    anim(human_createfire, 0);
    p_delay(5);

    %rcu_abyssal_generator = 17;
    spotanim_map(firewave_impact, loc_coord, 128, 0);
    p_teleport(loc_param(rcu_outer_enter_coord));
    sound_synth(boil_burst, 0, 0);
    p_delay(1);

    mes("...and manage to burn it down and get past.");
    p_delay(0);

    p_telejump(loc_param(rcu_outer_inner_coord));
    p_delay(0);

    clearqueue(damage_player);
    %rcu_abyssal_generator = 0;
    cam_reset;
    stat_advance(firemaking, 250);
} else {
    clearqueue(damage_player);
    mes("...but fail to burn it out of your way.");
}

[label,rcu_go_through_passage]
clearqueue(damage_player);
p_telejump(loc_param(rcu_outer_inner_coord));

[proc,rcu_loc_face_center]
def_int $x_off = calc(lc_width(loc_type) / 2);
def_int $z_off = calc(lc_length(loc_type) / 2);

facesquare(movecoord(loc_coord, $x_off, 0, $z_off));
